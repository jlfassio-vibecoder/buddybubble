{
  "name": "buddybubble",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "apps/*"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "next dev --port 3000 --hostname 0.0.0.0",
    "build": "next build",
    "start": "next start",
    "clean": "rm -rf .next dist",
    "lint": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check:storefront": "npm run astro:check -w storefront",
    "build:storefront": "npm run build -w storefront",
    "verify:storefront": "npm run check:storefront && npm run build:storefront",
    "check": "npm run format:check && npm run lint && npm run build && npm run check:storefront",
    "test": "tsx scripts/check-agent-coupling.ts && vitest run",
    "test:e2e": "playwright test",
    "check:agent-coupling": "tsx scripts/check-agent-coupling.ts",
    "db:provision-agents": "tsx scripts/provision-agents.ts",
    "db:audit-agent-avatars": "tsx scripts/audit-agent-avatars.ts",
    "prepare": "node -e \"if (process.env.CI || process.env.VERCEL) process.exit(0); require('child_process').execSync('npx husky', { stdio: 'inherit', shell: true })\""
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx,mjs,cjs,json,css,md,mdx,yml,yaml}": "prettier --write"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/genai": "^1.29.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@stripe/react-stripe-js": "^6.1.0",
    "@stripe/stripe-js": "^9.1.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.3",
    "@vercel/kv": "^3.0.0",
    "agora-access-token": "^2.0.4",
    "agora-rtc-sdk-ng": "^4.24.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.3",
    "google-auth-library": "^10.6.2",
    "jsonrepair": "^3.13.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "next": "^15.2.4",
    "next-themes": "^0.4.6",
    "pdfjs-dist": "^4.10.38",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.9.0",
    "remark-gfm": "^4.0.1",
    "resend": "^6.10.0",
    "shadcn": "^4.1.2",
    "sonner": "^2.0.7",
    "stripe": "^22.0.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "twilio": "^5.13.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@playwright/test": "1.52.0",
    "@tailwindcss/postcss": "^4.1.14",
    "@testing-library/react": "^16.3.2",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "happy-dom": "^16.7.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "only-allow": "1.1.1",
    "prettier": "^3.5.3",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.19.3",
    "typescript": "~5.8.2",
    "vitest": "^3.0.5"
  },
  "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017"
}
