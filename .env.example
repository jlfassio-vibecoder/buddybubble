# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# Use one of: legacy anon key, or publishable key from Supabase UI (see https://supabase.com/ui )
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# Server-only (never NEXT_PUBLIC_*): service_role secret from Supabase → API.
# Troubleshooting "Project mismatch" / wrong ref: if `printenv SUPABASE_SERVICE_ROLE_KEY` prints anything
# in the terminal where you run `npm run dev`, that exported value OVERRIDES .env and .env.local.
# Fix: `unset SUPABASE_SERVICE_ROLE_KEY` (and remove it from ~/.zshrc if you added it), then restart dev.
# SUPABASE_SERVICE_ROLE_KEY=

# Canonical app origin (first match wins): OAuth/email redirects, invite links, QR, email/SMS URLs.
# Priority: NEXT_PUBLIC_SITE_URL → NEXT_PUBLIC_APP_ORIGIN → NEXT_PUBLIC_APP_URL → NEXT_PUBLIC_VERCEL_URL → localhost.
# Production (Vercel): set NEXT_PUBLIC_SITE_URL=https://app.buddybubble.app (aligns with Supabase redirect URLs).
# Local: unset SITE_URL to use http://localhost:3000, or set SITE_URL=http://localhost:3000 explicitly.
# Add {origin}/auth/callback under Supabase → Authentication → URL Configuration → Redirect URLs.
# NEXT_PUBLIC_SITE_URL=https://app.example.com
# Optional fallbacks if SITE_URL is unset:
# NEXT_PUBLIC_APP_ORIGIN=https://app.example.com
# NEXT_PUBLIC_APP_URL=https://app.example.com

# Live marketing iframe demo: workspace UUID visitors land in after /demo (anonymous auth).
# POST /api/demo/join adds anonymous users to this workspace (requires SUPABASE_SERVICE_ROLE_KEY).
# Comma-separated allowlist (server). If unset, only NEXT_PUBLIC_DEMO_WORKSPACE_ID is allowed.
# Example local+prod workspaces on one Supabase: DEMO_WORKSPACE_IDS=uuid-local,uuid-prod
# DEMO_WORKSPACE_IDS=
# Fallback single ID when storefront does not pass ?workspace= (optional if DEMO_WORKSPACE_IDS is set).
# NEXT_PUBLIC_DEMO_WORKSPACE_ID=

# Comma-separated origins allowed to iframe /demo and /app (Content-Security-Policy frame-ancestors).
# Production: include every marketing origin that embeds the CRM (exact scheme+host+port).
# Example: http://localhost:4321,https://www.buddybubble.app,https://buddybubble.vercel.app
# MARKETING_FRAME_ANCESTORS=
#
# --- Vercel (CRM project for app.yourdomain.com) ---
# 1) Settings → Git → Production Branch = branch that contains src/app/demo/
# 2) Deployments → Redeploy production after merge (fixes /demo 404 if route was missing)
# 3) Settings → Environment Variables (Production): SUPABASE_SERVICE_ROLE_KEY, DEMO_WORKSPACE_IDS or
#    NEXT_PUBLIC_DEMO_WORKSPACE_ID, NEXT_PUBLIC_SUPABASE_*, optional MARKETING_FRAME_ANCESTORS,
#    NEXT_PUBLIC_SITE_URL=https://app.buddybubble.app
# 4) Supabase Dashboard → Authentication → URL Configuration → Redirect URLs: add
#    https://app.buddybubble.app/auth/callback and every preview URL you use, plus local if needed

# Stripe — subscriptions, trials, and billing (business/fitness workspaces only)
# https://dashboard.stripe.com/apikeys
# Use restricted keys in production (read/write only the resources BuddyBubble needs).
#
# **Test vs live:** `sk_test_` / `pk_test_` must be used together; `sk_live_` / `pk_live_` together.
# Vercel Production (VERCEL_ENV=production) refuses `sk_test_`. Mismatched modes throw at server startup.
#
# STRIPE_SECRET_KEY=sk_live_...           # server-side only — never expose to the browser
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...  # safe for browser (Stripe Elements)
#
# **Test catalog (required when STRIPE_SECRET_KEY is sk_test_):** in Dashboard with “View test data” on,
# set JSON mapping plan keys → { productId, defaultPriceId }. You only need **athlete** + **host** for
# sandbox fitness; missing business keys (pro, studio, coach_pro, studio_pro) reuse **host**’s Stripe
# price (else **athlete**). Split across STRIPE_TEST_CATALOG_JSON + STRIPE_TEST_CATALOG_JSON_OVERLAY if needed.
# STRIPE_TEST_CATALOG_JSON={"athlete":{"productId":"prod_...","defaultPriceId":"price_..."},"host":{"productId":"prod_...","defaultPriceId":"price_..."}}
# See docs/stripe-test-catalog-sandbox-fitness.example.json for a copy-paste starter.
#
# Subscribe modal plan list: each tier’s **listPriceLabel** in `src/lib/stripe-plans.ts` (keep in sync with
# Stripe default recurring USD prices). **GET /api/stripe/plan-pricing** still returns Stripe-reported amounts
# for tools / verification; business tiers in test that reuse Host’s price ID only affect **charged** amount
# until you add real `price_…` per key in STRIPE_TEST_CATALOG_JSON_OVERLAY.
#
# **Billing funnel analytics:** rows go to `billing_funnel_events` (see migration). Server + client POST `/api/billing/analytics`.
#
# Webhook signing secret — from Stripe Dashboard → Webhooks → your endpoint → Signing secret.
# For local dev use the Stripe CLI: stripe listen --forward-to localhost:3000/api/stripe/webhook
#   The CLI prints a whsec_... secret; set that as STRIPE_WEBHOOK_SECRET while listening.
# STRIPE_WEBHOOK_SECRET=whsec_...
#
# Events to enable on the webhook endpoint:
#   customer.subscription.created
#   customer.subscription.updated
#   customer.subscription.deleted
#   customer.subscription.trial_will_end
#   invoice.payment_succeeded
#   invoice.payment_failed
#
# Customer Portal must be configured in Stripe Dashboard → Billing → Customer portal
# before GET /api/stripe/portal will work.

# Resend — workspace email invites (People & invites → email)
# https://resend.com/api-keys — create an API key, verify a domain, then use a from-address on that domain.
RESEND_API_KEY=re_your_api_key
RESEND_FROM="BuddyBubble <onboarding@your-verified-domain.com>"

# Twilio — SMS invites (People & invites → SMS)
# https://console.twilio.com/ — Account SID + Auth Token; then either a Messaging Service or a From number.
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_FROM_NUMBER=+15555550123

# --- Supabase CLI (recommended for db push; no manual connection URL) ---
# From repo root, once per machine clone. All three steps; login alone is NOT enough.
#   1. supabase login
#   2. supabase link --project-ref YOUR_PROJECT_REF   # required or "db push" says "Cannot find project ref"
#      If link says "Unauthorized": the logged-in CLI user must own or be in the org for that project.
#      Fix: Dashboard → Account → Access tokens → create token → supabase login --token YOUR_TOKEN
#      Or unset a stale SUPABASE_ACCESS_TOKEN in your shell, then supabase logout && supabase login again.
#      (After link succeeds, password prompt = Database password in Project Settings → Database, not anon key)
#   3. supabase db push
# Link state is stored under supabase/.temp/ (gitignored). For link issues, try --skip-pooler
# only if you need a direct db host instead of the pooler.
#
# Optional: SUPABASE_DATABASE_URL for psql/other tools. Prefer Session pooler (port 6543,
# user postgres.YOUR_PROJECT_REF) if direct db host on :5432 fails locally.
# Do not paste placeholder text with angle brackets into zsh; "<foo>" is treated as redirection.

# Marketing storefront live sandbox: comma-separated auth user UUIDs allowed to post team replies
# via POST /api/storefront-sandbox/reply and /app/storefront-sandbox (uses SUPABASE_SERVICE_ROLE_KEY server-side).
# STOREFRONT_SANDBOX_OWNER_USER_IDS=

# Vercel — register CRM-saved custom domains on the Astro storefront project (Phase 4)
# Create a token at Vercel → Account Settings → Tokens. Project ID is in the storefront project → Settings.
# VERCEL_API_TOKEN=
# VERCEL_STOREFRONT_PROJECT_ID=
# Optional when the project lives under a team:
# VERCEL_TEAM_ID=

# --- Storefront AI preview (POST /api/ai/storefront-preview) ---
# Cloudflare Turnstile **secret** (Widgets → your widget → Secret key). Required in production.
# TURNSTILE_SECRET_KEY=
# Alias supported: CLOUDFLARE_TURNSTILE_SECRET=
# Local only: skip Turnstile verification (never enable in production):
# ALLOW_STOREFRONT_PREVIEW_WITHOUT_TURNSTILE=1
#
# Shared rate limit across instances (Vercel KV / Upstash-backed). If unset, a per-process memory limiter is used (dev only).
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
#
# Browser cross-origin calls to the Next app (optional; prefer Astro same-origin proxy):
# STOREFRONT_PREVIEW_CORS_ORIGINS=http://localhost:4321,https://your-storefront.example.com
