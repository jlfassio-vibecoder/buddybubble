# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# Use one of: legacy anon key, or publishable key from Supabase UI (see https://supabase.com/ui )
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# Production: canonical CRM origin for OAuth / email-confirm redirects in production builds.
# Omit locally: `next dev` always uses the browser origin so confirmation links stay on localhost.
# If links still open production, add your local callback to Supabase → Authentication →
# URL Configuration → Redirect URLs, e.g. http://localhost:3000/auth/callback
# NEXT_PUBLIC_SITE_URL=https://app.example.com

# Live marketing iframe demo: workspace UUID visitors land in after /demo (anonymous auth).
# POST /api/demo/join adds anonymous users to this workspace (requires SUPABASE_SERVICE_ROLE_KEY).
# Comma-separated allowlist (server). If unset, only NEXT_PUBLIC_DEMO_WORKSPACE_ID is allowed.
# Example local+prod workspaces on one Supabase: DEMO_WORKSPACE_IDS=uuid-local,uuid-prod
# DEMO_WORKSPACE_IDS=
# Fallback single ID when storefront does not pass ?workspace= (optional if DEMO_WORKSPACE_IDS is set).
# NEXT_PUBLIC_DEMO_WORKSPACE_ID=

# Comma-separated origins allowed to iframe /demo and /app (Content-Security-Policy frame-ancestors).
# Production: include every marketing origin that embeds the CRM (exact scheme+host+port).
# Example: http://localhost:4321,https://www.buddybubble.app,https://buddybubble.vercel.app
# MARKETING_FRAME_ANCESTORS=
#
# --- Vercel (CRM project for app.yourdomain.com) ---
# 1) Settings → Git → Production Branch = branch that contains src/app/demo/
# 2) Deployments → Redeploy production after merge (fixes /demo 404 if route was missing)
# 3) Settings → Environment Variables (Production): SUPABASE_SERVICE_ROLE_KEY, DEMO_WORKSPACE_IDS or
#    NEXT_PUBLIC_DEMO_WORKSPACE_ID, NEXT_PUBLIC_SUPABASE_*, optional MARKETING_FRAME_ANCESTORS,
#    NEXT_PUBLIC_SITE_URL=https://app.buddybubble.app
# 4) Supabase Dashboard → Authentication → URL Configuration → Redirect URLs: add
#    https://app.buddybubble.app/auth/callback and every preview URL you use, plus local if needed

# Resend — workspace email invites (People & invites → email)
# https://resend.com/api-keys — create an API key, verify a domain, then use a from-address on that domain.
RESEND_API_KEY=re_your_api_key
RESEND_FROM="BuddyBubble <onboarding@your-verified-domain.com>"

# Twilio — SMS invites (People & invites → SMS)
# https://console.twilio.com/ — Account SID + Auth Token; then either a Messaging Service or a From number.
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_FROM_NUMBER=+15555550123

# --- Supabase CLI (recommended for db push; no manual connection URL) ---
# From repo root, once per machine clone. All three steps; login alone is NOT enough.
#   1. supabase login
#   2. supabase link --project-ref YOUR_PROJECT_REF   # required or "db push" says "Cannot find project ref"
#      If link says "Unauthorized": the logged-in CLI user must own or be in the org for that project.
#      Fix: Dashboard → Account → Access tokens → create token → supabase login --token YOUR_TOKEN
#      Or unset a stale SUPABASE_ACCESS_TOKEN in your shell, then supabase logout && supabase login again.
#      (After link succeeds, password prompt = Database password in Project Settings → Database, not anon key)
#   3. supabase db push
# Link state is stored under supabase/.temp/ (gitignored). For link issues, try --skip-pooler
# only if you need a direct db host instead of the pooler.
#
# Optional: SUPABASE_DATABASE_URL for psql/other tools. Prefer Session pooler (port 6543,
# user postgres.YOUR_PROJECT_REF) if direct db host on :5432 fails locally.
# Do not paste placeholder text with angle brackets into zsh; "<foo>" is treated as redirection.

# Marketing storefront live sandbox: comma-separated auth user UUIDs allowed to post team replies
# via POST /api/storefront-sandbox/reply and /app/storefront-sandbox (uses SUPABASE_SERVICE_ROLE_KEY server-side).
# STOREFRONT_SANDBOX_OWNER_USER_IDS=

# Vercel — register CRM-saved custom domains on the Astro storefront project (Phase 4)
# Create a token at Vercel → Account Settings → Tokens. Project ID is in the storefront project → Settings.
# VERCEL_API_TOKEN=
# VERCEL_STOREFRONT_PROJECT_ID=
# Optional when the project lives under a team:
# VERCEL_TEAM_ID=
