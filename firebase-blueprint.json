{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "avatar": { "type": "string" },
        "role": { "type": "string", "enum": ["Admin", "Lead", "Member", "Guest"] },
        "department": { "type": "string" },
        "channelIds": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["online", "offline", "away"] },
        "lastSeen": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email"]
    },
    "Channel": {
      "title": "Channel",
      "description": "A communication and task channel",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "icon": { "type": "string" }
      },
      "required": ["id", "name", "icon"]
    },
    "Message": {
      "title": "Message",
      "description": "A chat message",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "sender": { "type": "string" },
        "senderAvatar": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "department": { "type": "string" },
        "uid": { "type": "string" },
        "parentId": { "type": "string" },
        "threadCount": { "type": "number" }
      },
      "required": ["id", "sender", "content", "timestamp", "department", "uid"]
    },
    "Task": {
      "title": "Task",
      "description": "A Kanban task",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["Todo", "In Progress", "Done"] },
        "priority": { "type": "string", "enum": ["Low", "Medium", "High"] },
        "assignee": { "type": "string" },
        "assigner": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "dueDate": { "type": "string", "format": "date-time" },
        "channelId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "uid": { "type": "string" }
      },
      "required": ["id", "title", "status", "priority", "assignee", "createdAt", "uid"]
    },
    "TaskTemplate": {
      "title": "Task Template",
      "description": "A reusable task template",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "priority": { "type": "string", "enum": ["Low", "Medium", "High"] },
        "tags": { "array": { "items": { "type": "string" } } },
        "channelId": { "type": "string" },
        "uid": { "type": "string" }
      },
      "required": ["id", "name", "title", "priority", "uid"]
    },
    "Notification": {
      "title": "Notification",
      "description": "A user notification",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string", "enum": ["thread_reply", "task_assigned", "mention"] },
        "relatedId": { "type": "string" },
        "read": { "type": "boolean" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "title", "content", "type", "read", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "User" },
      "description": "User profiles"
    },
    "/channels/{channelId}": {
      "schema": { "$ref": "Channel" },
      "description": "Workspace channels"
    },
    "/messages/{messageId}": {
      "schema": { "$ref": "Message" },
      "description": "Chat messages"
    },
    "/tasks/{taskId}": {
      "schema": { "$ref": "Task" },
      "description": "Kanban tasks"
    },
    "/templates/{templateId}": {
      "schema": { "$ref": "TaskTemplate" },
      "description": "Task templates"
    },
    "/notifications/{notificationId}": {
      "schema": { "$ref": "Notification" },
      "description": "User notifications"
    }
  }
}
