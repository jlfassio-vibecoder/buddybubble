# Copy from the CRM `.env.local`: use the SAME Supabase project URL and anon (or publishable) key.
# Replace every placeholder below — if you leave `your-project-ref` / `your-anon-key`, the demo will
# not connect (no WebSocket spam) and you will see an in-UI note instead.
#
# Astro exposes `PUBLIC_*` to the browser. After migration `20260426100000_storefront_sandbox_messages.sql`,
# # Welcome / # Q&A sync via Realtime; team replies use the CRM.
PUBLIC_SUPABASE_URL=https://YOUR_REAL_PROJECT_REF.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your_real_anon_or_publishable_key

# Next.js CRM **origin only** (scheme + host + port). No path. Never paste /app/workspace-id here —
# that produces a broken iframe URL like …/app/{uuid}/demo (404). Examples:
#   http://localhost:3000   (only when BOTH storefront + CRM are local)
#   https://app.buddybubble.app
# Production storefront on Vercel: set PUBLIC_APP_ORIGIN to your **live** CRM URL — NOT localhost
# (iframe + login handoff would target the visitor's machine). Same vars must exist in Vercel
# → Environment Variables for the storefront project; .env is not deployed.
# Do NOT set this to the Astro marketing URL (iframe would 404 on the storefront host).
# PUBLIC_APP_ORIGIN=http://localhost:3000
#
# Workspace UUID shown in the live iframe (must match a row in CRM DEMO_WORKSPACE_IDS or NEXT_PUBLIC_DEMO_WORKSPACE_ID).
# Local: copy from /app/<uuid> in the address bar. Production: your public demo workspace.
# PUBLIC_DEMO_WORKSPACE_ID=
